{
  "name": "tomo-school",
  "version": "0.1.0",
  "private": true,
  "description": "Tomo School OS — AI-supported mastery-based learning (Concept Blocks + PATH). Working core loop, deployable on Cloudflare Pages.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:curriculum": "node scripts/import-curriculum.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "xlsx": "^0.18.5"
  }
}
